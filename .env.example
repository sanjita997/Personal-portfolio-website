CONTACT_TO=info@sanjitamhrzn.com

# FormSubmit fallback sends consultation requests to CONTACT_TO without SMTP.
# The first message may require one-time activation from the recipient inbox.
ENABLE_FORMSUBMIT_FALLBACK=true
API_EMAIL_DELIVERY=false

# Optional direct SMTP setup if you have mailbox SMTP credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
CONTACT_FROM=
