CONTACT_TO=info@sanjitamhrzn.com

# FormSubmit sends consultation requests to CONTACT_TO without SMTP.
# The first message may require a one-time activation from the recipient inbox.
ENABLE_FORMSUBMIT_FALLBACK=true
API_EMAIL_DELIVERY=false

# Leave SMTP blank unless you have real mailbox SMTP credentials for info@sanjitamhrzn.com.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
CONTACT_FROM=
